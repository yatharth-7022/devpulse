generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid())
  githubId     Int       @unique
  username     String    @unique
  email        String?
  avatarUrl    String?
  displayName  String?
  // Stored encrypted at rest — never returned to the client
  accessToken  String?
  lastSynced   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  repositories Repository[]
  commits      Commit[]
  syncLogs     SyncLog[]

  @@index([githubId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Repositories
// ---------------------------------------------------------------------------

model Repository {
  id           String    @id @default(uuid())
  userId       String
  githubRepoId Int       @unique
  name         String
  fullName     String    @unique
  description  String?
  isPrivate    Boolean   @default(false)
  defaultBranch String   @default("main")
  stars        Int       @default(0)
  forks        Int       @default(0)
  openIssues   Int       @default(0)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  commits   Commit[]
  languages RepoLanguage[]
  syncLogs  SyncLog[]

  @@index([userId])
  @@index([githubRepoId])
  @@map("repositories")
}

// ---------------------------------------------------------------------------
// Commits
// ---------------------------------------------------------------------------

model Commit {
  id           String   @id @default(uuid())
  userId       String
  repositoryId String
  sha          String
  message      String
  authorName   String
  authorEmail  String
  authorLogin  String?
  committedAt  DateTime
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  // Composite unique: same commit SHA per repo is de-duped on upsert
  @@unique([repositoryId, sha])
  // heatmap + streak queries
  @@index([userId, committedAt])
  // per-repo commit stats
  @@index([repositoryId, committedAt])
  @@map("commits")
}

// ---------------------------------------------------------------------------
// Repo Languages
// ---------------------------------------------------------------------------

model RepoLanguage {
  id           String   @id @default(uuid())
  repositoryId String
  language     String
  bytes        BigInt   @default(0)
  percentage   Float    @default(0)
  syncedAt     DateTime @default(now())

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  // One language entry per repo
  @@unique([repositoryId, language])
  @@index([repositoryId])
  @@map("repo_languages")
}

// ---------------------------------------------------------------------------
// Sync Logs
// ---------------------------------------------------------------------------

enum SyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model SyncLog {
  id           String      @id @default(uuid())
  userId       String
  repositoryId String?
  status       SyncStatus  @default(PENDING)
  message      String?
  errorDetails String?
  startedAt    DateTime    @default(now())
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  repository Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([repositoryId])
  @@index([status])
  @@map("sync_logs")
}
